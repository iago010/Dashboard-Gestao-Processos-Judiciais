table DJR_998
	lineageTag: e15fcdc7-26de-450a-8161-c7ef90e5ba04

	measure 'Total Processos' = COUNTROWS('DJR_998')
		formatString: 0
		lineageTag: c8fbe5d8-8657-412d-9ded-4c722c3b5198

	measure 'Processos Ativos' =
			
			CALCULATE(
			    COUNTROWS('DJR_998'),
			    'DJR_998'[Status] = "Ativo"
			)
		formatString: 0
		lineageTag: e1d8ae72-ab6c-4daf-b82b-d2150c67c5f9

	measure 'Processos Arquivados' =
			
			CALCULATE(
			    COUNTROWS('DJR_998'),
			    'DJR_998'[Status] = "Arquivado"
			)
		formatString: 0
		lineageTag: 5b68c85a-3085-47aa-bc2b-a08c8aa0944c

	measure 'Arquivado Cancelamento' =
			
			CALCULATE(
			    COUNTROWS('DJR_998'),
			    'DJR_998'[Status] = "arquivado por cancelamento da distribuição"
			)
		formatString: 0
		lineageTag: bd06bf44-4b4c-4f08-8302-b778529aedbe

	measure 'Arquivado provisoriamente' =
			
			CALCULATE(
			    COUNTROWS('DJR_998'),
			    'DJR_998'[Status] = "Arquivado provisoriamente"
			)
		formatString: 0
		lineageTag: 5e09aaf5-5b33-4fb3-a928-50b96f5c84c4

	measure 'inst superior' = ```
			
			 CALCULATE(
			    COUNTROWS('DJR_998'),
			    'DJR_998'[Status] = "Em instância superior"
			 )   
			```
		formatString: 0
		lineageTag: 83c6cac5-ff8f-4680-ad65-a48329ac07f1

	measure 'Suspenso ou sobrestado' =
			
			CALCULATE(
			    COUNTROWS('DJR_998'),
			    'DJR_998'[Status] = "Suspenso ou sobrestado"
			)
		formatString: 0
		lineageTag: 471379fd-05dd-4ff1-9664-dd73906b391e

	measure 'Ranking Vara' =
			
			RANKX(
			    ALL('DJR_998'[Vara]),
			    [Total Processos],
			    ,
			    DESC
			)
		formatString: 0
		lineageTag: 38a86961-591e-43d1-a974-a95346f796fa

	measure 'Tipo Cliente' =
			
			SWITCH(
			    TRUE(),
			    [Total Processos] >= 10, "Alto volume",
			    [Total Processos] >= 5, "Médio volume",
			    "Baixo volume"
			)
		lineageTag: 373e79bf-9c5b-40ab-afcf-158c392cf39c

	measure 'Processos Antigos Ativos' =
			
			CALCULATE(
			    COUNTROWS('DJR_998'),
			    'DJR_998'[Idade Processo] > 365,
			    'DJR_998'[Status] = "ativo"
			)
		formatString: 0
		lineageTag: c84468ff-06b2-4411-aa7d-9330e293a95e

