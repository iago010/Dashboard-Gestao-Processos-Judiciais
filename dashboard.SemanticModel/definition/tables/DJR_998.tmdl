	column 'Idade Processo' =
			
			DATEDIFF('DJR_998'[Entrada], TODAY(), DAY)
		formatString: 0
		lineageTag: 32d1bc4f-b797-4f8e-b249-0e62d417901a
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Faixa Tempo' =
			
			SWITCH(
			    TRUE(),
			    'DJR_998'[Idade Processo] <= 90, "Até 3 meses",
			    'DJR_998'[Idade Processo] <= 180, "3 a 6 meses",
			    'DJR_998'[Idade Processo] <= 365, "6 meses a 1 ano",
			    "Mais de 1 ano"
			)
		lineageTag: 8f863642-2592-4830-9dba-0fec3511e877
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

